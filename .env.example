# Ledger Recon Agent environment example
# Copy to .env for local development and fill values as needed.

# Workspace root used by Coze-generated scripts and src/agents/agent.py.
# In local checkout, set this to the repository root.
COZE_WORKSPACE_PATH=/path/to/ledger-recon-agent

# Coze project environment. Use DEV locally if you want scripts/setup.sh to create assets/.
COZE_PROJECT_ENV=DEV

# LLM provider config. The agent uses langchain_openai.ChatOpenAI with these values.
COZE_WORKLOAD_IDENTITY_API_KEY=your-model-api-key
COZE_INTEGRATION_MODEL_BASE_URL=https://example.com/v1

# Optional PostgreSQL checkpoint storage. If unset or unreachable, the app falls back
# to in-memory checkpoints that do not persist across restarts.
PGDATABASE_URL=postgresql://user:password@localhost:5432/ledger_recon

# Optional S3-compatible object storage used by src/storage/s3/s3_storage.py.
COZE_BUCKET_ENDPOINT_URL=https://s3.example.com
COZE_BUCKET_NAME=your-bucket-name
COZE_BUCKET_ACCESS_KEY=your-access-key
COZE_BUCKET_SECRET_KEY=your-secret-key

# Optional runtime tuning.
# Reconciliation batch size is passed as tool argument; default is 10000 rows.
# HTTP /run timeout is currently defined in src/main.py as TIMEOUT_SECONDS=900.
